# ── AppAholic Email Server — Environment Variables ──────────────────────
# Copy this file to ".env" and fill in your real values.
# NEVER commit your actual ".env" file to GitHub — it's already in .gitignore.

# Your Gmail address (the one sending emails)
GMAIL_USER=youremail@gmail.com

# Gmail App Password — NOT your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google Account first)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where admin alerts go (new requests, new sales, new signups).
# Can be the same as GMAIL_USER, or a different inbox.
ADMIN_EMAIL=youremail@gmail.com

# Your deployed frontend URL (used in email buttons/links).
# Use your Vercel production URL once deployed.
SITE_URL=https://appaholic.justservices.pro

# Comma-separated list of allowed origins for CORS.
# Add your Vercel preview + production URLs here.
ALLOWED_ORIGIN=https://appaholic.justservices.pro,http://localhost:3000

# Port for local development (Vercel ignores this in production)
PORT=4000

# ── Google OAuth (only needed if using "Sign in with Google") ───────────
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxx
GOOGLE_CALLBACK_URL=https://api.appaholic.justservices.pro/auth/google/callback
